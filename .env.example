# ---------------------------------------------------------------------------
# whatsapp-worker — environment template
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Postgres (long-lived session pool) ---
#
# Any Postgres works. If you're on Supabase, use the SESSION pooler
# (port 5432) — the transaction pooler is sized for serverless and won't
# hold up under the worker's long-lived connections. The worker's Prisma
# schema scope (only worker-owned tables declared) keeps it from touching
# other applications' tables when sharing a database.
DIRECT_URL=postgresql://user:password@host:5432/dbname
# Optional override — point the worker at a separate Postgres if you
# decide to fully isolate. Falls back to DIRECT_URL.
# WORKER_DATABASE_URL=

# --- Quiet hours ---
#
# Messages outside this window are rejected with 503 + Retry-After.
# Hours are 0–23 in the specified IANA timezone.
# Defaults: 07:00–21:00 Africa/Nairobi (EAT).
QUIET_HOUR_START=7
QUIET_HOUR_END=21
QUIET_HOUR_TZ=Africa/Nairobi

# --- Worker auth (legacy shared header) ---
#
# Shared static secret. Every authenticated request must send it as
# `X-Worker-Secret`. Kept until the per-caller HMAC scheme (see TODO §1)
# is rolled out.
WHATSAPP_WORKER_SECRET=

# --- Listen socket ---
#
# Cloudflare Tunnel terminates HTTPS and forwards to loopback. Bind to
# 127.0.0.1 in production so the worker is never reachable directly from
# the host's network interface.
PORT=3001
WHATSAPP_WORKER_PORT=3001
WHATSAPP_WORKER_HOST=127.0.0.1

# --- Chromium / Chrome (Ubuntu 22.04 gotcha) ---
#
# Set ONLY if you installed Google Chrome stable from the official .deb.
# Omit to let Puppeteer use its bundled Chromium under ~/.cache/puppeteer/.
# Never `apt install chromium-browser` on 22.04 — that's a snap and breaks
# Puppeteer's sandbox.
# PUPPETEER_EXECUTABLE_PATH=/opt/google/chrome/google-chrome

# --- Body variation (anti-ban) ---
#
# When `on` (default), every send appends one of a small set of trailing
# whitespace variants so 100 identical-input messages don't share a single
# byte fingerprint at the spam scorer. Whitespace-only — recipients see no
# visible change (WhatsApp UI trims trailing whitespace). Set to `off` only
# when byte-identical bodies are required (e.g. one-off admin sends).
WHATSAPP_BODY_VARIATION=on

# --- Local session profile path ---
#
# Where whatsapp-web.js's `LocalAuth` writes browser profiles before the
# worker tars them up and persists into Postgres. Default is fine for
# single-host deploys.
WHATSAPP_SESSION_DIR=.wwebjs_auth
WHATSAPP_CACHE_DIR=.wwebjs_cache
