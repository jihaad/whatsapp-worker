# ---------------------------------------------------------------------------
# whatsapp-worker — environment template
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Postgres (long-lived session pool) ---
#
# Any Postgres works. If you're on Supabase, use the SESSION pooler
# (port 5432) — the transaction pooler is sized for serverless and won't
# hold up under the worker's long-lived connections. The worker's Prisma
# schema scope (only worker-owned tables declared) keeps it from touching
# other applications' tables when sharing a database.
DIRECT_URL=postgresql://user:password@host:5432/dbname

# --- Quiet hours ---
#
# Messages outside this window are rejected with 503 + Retry-After.
# START is 0–23 (inclusive lower bound), END is 1–24 (exclusive upper bound).
# Defaults: 07:00–21:00 Africa/Nairobi (EAT).
#
# Set START=0 and END=24 to disable quiet hours entirely (always live). In
# that case the worker short-circuits the time check and QUIET_HOUR_TZ has
# no effect — set it to whatever you'd want active if you re-enabled the
# window later. TZ matters as soon as start/end describe a real window.
#
# Editable at runtime via PUT /v1/config/quiet-hours (or the settings modal
# on the dashboard). Changes apply immediately AND are written back here so
# they survive a restart — no `pm2 restart` needed.
QUIET_HOUR_START=7
QUIET_HOUR_END=21
QUIET_HOUR_TZ=Africa/Nairobi

# --- Worker auth (legacy shared header) ---
#
# Shared static secret. Every authenticated request must send it as
# `X-Worker-Secret`. Kept until the per-caller HMAC scheme (see TODO §1)
# is rolled out.
WHATSAPP_WORKER_SECRET=

# --- Listen socket ---
#
# Cloudflare Tunnel terminates HTTPS and forwards to loopback. Bind to
# 127.0.0.1 in production so the worker is never reachable directly from
# the host's network interface.
PORT=3001
WHATSAPP_WORKER_PORT=3001
WHATSAPP_WORKER_HOST=127.0.0.1

# --- Chromium / Chrome (Ubuntu 22.04 gotcha) ---
#
# Set ONLY if you installed Google Chrome stable from the official .deb.
# Omit to let Puppeteer use its bundled Chromium under ~/.cache/puppeteer/.
# Never `apt install chromium-browser` on 22.04 — that's a snap and breaks
# Puppeteer's sandbox.
# PUPPETEER_EXECUTABLE_PATH=/opt/google/chrome/google-chrome

# --- Body variation (anti-ban) ---
#
# When `on` (default), every send appends one of a small set of trailing
# whitespace variants so 100 identical-input messages don't share a single
# byte fingerprint at the spam scorer. Whitespace-only — recipients see no
# visible change (WhatsApp UI trims trailing whitespace). Set to `off` only
# when byte-identical bodies are required (e.g. one-off admin sends).
WHATSAPP_BODY_VARIATION=on

# --- Per-account min inter-send spacing (anti-ban) ---
#
# Randomised minimum gap between consecutive sends on the SAME account. The
# per-minute token bucket caps rate but allows bursts; sub-second / fixed
# intervals read as automation to WhatsApp's spam scorer. A single send that
# arrives sooner than the gap is rejected with 429 ACCOUNT_SPACING + Retry-After
# (the caller paces); bulk batches wait the gap out internally between messages.
# Defaults: 15–45s once an account is past warmup, 30–60s during the warmup
# window. Lower only if you accept more ban risk.
# SEND_SPACING_MIN_MS=15000
# SEND_SPACING_MAX_MS=45000
# SEND_SPACING_WARMUP_MIN_MS=30000
# SEND_SPACING_WARMUP_MAX_MS=60000

# --- Watchdog DB-reconcile backoff (anti-ban) ---
#
# When the watchdog finds a saved session that failed to re-initialise, it
# waits this long before retrying that session (instead of every 5-min sweep)
# — repeated re-auth attempts look like "logging in repeatedly", a ban signal.
# After 3 consecutive failures it fires a stuck/connect alert instead of
# silently looping. Default 1800000 (30 min).
# RECONCILE_COOLDOWN_MS=1800000

# --- Operator alerts (ntfy.sh) ---
#
# Pings you when a session needs manual attention: login rejected
# (auth_failure), saved login thrown out on restart (needs a fresh QR), or a
# send couldn't get the session connected within the wait window. Plain
# network blips that self-heal do NOT alert.
#
# Subscribe to the topic below in the ntfy app (App Store / Play Store), then
# set ALERT_NTFY_TOPIC to enable. Leave it blank to disable alerts entirely
# (the default — dev/local stays silent). Pick an unguessable topic name;
# public ntfy.sh topics are readable by anyone who knows the name.
ALERT_NTFY_TOPIC=
# Self-hosted ntfy instance (optional; defaults to the public server).
# ALERT_NTFY_SERVER=https://ntfy.sh
# Bearer token (optional; only for access-protected topics).
# ALERT_NTFY_TOKEN=
# Per-(session, problem) re-alert cooldown in ms (default 15 min) so a
# flapping session can't spam your phone.
# ALERT_COOLDOWN_MS=900000

# --- Send-time session restore wait ---
#
# On a cold/just-restarted worker, a send waits up to this long (ms) for the
# target session to finish restoring before giving up with a retry. Covers
# Chromium cold boot (~20s) plus slack. Lower it if your callers have tight
# HTTP timeouts. Default 30000.
# SEND_RESTORE_WAIT_MS=30000

# How long (ms) a session may sit in `connecting` before the 5-min watchdog
# treats it as wedged — WhatsApp Web launched but never finished loading, so
# it never reached `ready` or emitted a QR. When tripped, the worker alerts
# you (stuck_connecting) and nudges a cooldown-guarded reinit to self-heal.
# Default 180000 (3 min) — well past a healthy cold boot.
# STUCK_CONNECTING_MS=180000
