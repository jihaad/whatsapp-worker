// fd-whatsapp-worker — Prisma schema
//
// Slim, transport-only. The worker owns this single table; the FD app no
// longer declares `WhatsAppSession` in its own schema.
//
// `schoolId` is treated as an opaque tenant identifier — the worker has
// no concept of schools, classes, students, payments, or invoices. FD
// hands the worker a UUID and a recipient phone; the worker maintains a
// WhatsApp Web session per UUID and dispatches messages.
//
// **Schema sync rule:** the columns below must match FD's
// `prisma/schema.prisma` `WhatsAppSession` model byte-for-byte (other
// than the relation, which the worker doesn't have). Any change to either
// side requires updating the other and running `npm run generate` here.

generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

/// One row per linked school. The actual whatsapp-web.js session profile
/// (a tar.gz of the LocalAuth Chromium user-data dir) lives in
/// `sessionData`. Status is computed at runtime by the worker's in-memory
/// session manager and surfaced via the worker's HTTP API — it is NOT
/// persisted as a column. Restart = new in-memory state, sessionData
/// gives us the auth needed to reconnect without a fresh QR.
model WhatsAppSession {
  schoolId    String   @id @db.Uuid
  sessionData Bytes
  phoneNumber String?
  linkedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("whatsapp_sessions")
}
